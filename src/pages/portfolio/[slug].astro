export function getStaticPaths() {
  const slugs = [
    'feuerwerk-turnkunst-2024',
    'wildpark-lueneburger-heide-2023',
    'natur-2022',
    'sandkuhle-2019',
    'eulenkasten-2019',
    'vogelpark-walsrode-2017',
  ];
  return slugs.map(slug => ({ params: { slug } }));
}

const gallery = galleries.find(g => g.slug === Astro.params.slug)!;
---

<BaseLayout title={gallery.title} description={gallery.description}>

  <!-- Back link + header -->
  <div class="pt-32 pb-12 px-6 max-w-7xl mx-auto">
    <a href="/portfolio" class="text-zinc-500 hover:text-amber-400 transition-colors text-sm tracking-wider uppercase inline-flex items-center gap-2 mb-8">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
      </svg>
      Zurück zum Portfolio
    </a>
    <p class="text-amber-400 tracking-[0.2em] uppercase text-xs mb-2">{gallery.category} · {gallery.year}</p>
    <h1 class="text-4xl md:text-5xl font-thin">{gallery.title}</h1>
    <p class="text-zinc-400 mt-4 max-w-xl font-light leading-relaxed">{gallery.description}</p>
    <div class="mt-4 w-16 h-px bg-amber-400"></div>
  </div>

  <!-- Image Grid -->
  <div class="max-w-7xl mx-auto px-6 pb-20">
    <div class="columns-1 md:columns-2 gap-4 space-y-4">
      {gallery.images.map((src, i) => (
        <div class="gallery-item break-inside-avoid cursor-zoom-in" onclick={`openLightbox(${i})`}>
          <img
            src={src}
            alt={`${gallery.title} – Bild ${i + 1}`}
            class="w-full block"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        </div>
      ))}
    </div>
  </div>

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 bg-zinc-950/95 z-50 hidden items-center justify-center" onclick="closeLightbox()">
    <button class="absolute top-6 right-6 text-zinc-400 hover:text-white transition-colors" onclick="closeLightbox()">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
    <button id="lb-prev" class="absolute left-4 text-zinc-400 hover:text-white transition-colors p-4" onclick="event.stopPropagation(); prevImage()">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain" onclick="event.stopPropagation()" />
    <button id="lb-next" class="absolute right-4 text-zinc-400 hover:text-white transition-colors p-4" onclick="event.stopPropagation(); nextImage()">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/>
      </svg>
    </button>
  </div>

</BaseLayout>

<script define:vars={{ images: gallery.images }}>
  let current = 0;

  function openLightbox(index) {
    current = index;
    document.getElementById('lightbox-img').src = images[current];
    document.getElementById('lightbox').classList.remove('hidden');
    document.getElementById('lightbox').classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    document.getElementById('lightbox').classList.add('hidden');
    document.getElementById('lightbox').classList.remove('flex');
    document.body.style.overflow = '';
  }

  function prevImage() {
    current = (current - 1 + images.length) % images.length;
    document.getElementById('lightbox-img').src = images[current];
  }

  function nextImage() {
    current = (current + 1) % images.length;
    document.getElementById('lightbox-img').src = images[current];
  }

  document.addEventListener('keydown', (e) => {
    if (document.getElementById('lightbox').classList.contains('flex')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') prevImage();
      if (e.key === 'ArrowRight') nextImage();
    }
  });

  // Make functions global
  window.openLightbox = openLightbox;
  window.closeLightbox = closeLightbox;
  window.prevImage = prevImage;
  window.nextImage = nextImage;
</script>
