      'https://images.unsplash.com/photo-1577416412292-747c6607f055?w=1200&q=85',
      'https://images.unsplash.com/photo-1547483238-2cbf881a559f?w=1200&q=85',
      'https://images.unsplash.com/photo-1517649763962-0c623066013b?w=1200&q=85',
      'https://images.unsplash.com/photo-1535131749006-b7f58c99034b?w=1200&q=85',
    ],
  },
  {
    title: 'Wildpark Lüneburger Heide',
    year: '2023',
    category: 'Tierwelt',
    slug: 'wildpark-lueneburger-heide-2023',
    description: 'Faszinierende Tierwelt in der Lüneburger Heide – nah und unverstellt.',
    images: [
      'https://images.unsplash.com/photo-1474511320723-9a56873867b5?w=1200&q=85',
      'https://images.unsplash.com/photo-1518020382113-a7e8fc38eac9?w=1200&q=85',
      'https://images.unsplash.com/photo-1484557052118-f32bd25b45b5?w=1200&q=85',
      'https://images.unsplash.com/photo-1437622368342-7a3d73a34c8f?w=1200&q=85',
      'https://images.unsplash.com/photo-1456926631375-92c8ce872def?w=1200&q=85',
    ],
  },
  {
    title: 'Natur',
    year: '2022',
    category: 'Natur',
    slug: 'natur-2022',
    description: 'Naturaufnahmen aus Wäldern, Feldern und stillen Landschaften.',
    images: [
      'https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=1200&q=85',
      'https://images.unsplash.com/photo-1448375240586-882707db888b?w=1200&q=85',
      'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1200&q=85',
      'https://images.unsplash.com/photo-1426604966848-d7adac402bff?w=1200&q=85',
    ],
  },
  {
    title: 'Sandkuhle',
    year: '2019',
    category: 'Landschaft',
    slug: 'sandkuhle-2019',
    description: 'Strukturen, Licht und Schatten in einer ungewöhnlichen Landschaft.',
    images: [
      'https://images.unsplash.com/photo-1509316785289-025f5b846b35?w=1200&q=85',
      'https://images.unsplash.com/photo-1475924156734-496f6cac6ec1?w=1200&q=85',
      'https://images.unsplash.com/photo-1469474968028-56623f02e42e?w=1200&q=85',
    ],
  },
  {
    title: 'Eulenkasten',
    year: '2019',
    category: 'Tierwelt',
    slug: 'eulenkasten-2019',
    description: 'Geduldige Nahaufnahmen von Eulen in ihrem natürlichen Umfeld.',
    images: [
      'https://images.unsplash.com/photo-1543466835-00a7907e9de1?w=1200&q=85',
