---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Über mich" description="Über Guido Walther – Hobbyfotograf aus Norddeutschland">

  <div class="pt-32 max-w-5xl mx-auto px-6 pb-20">

    <!-- Header -->
    <div class="mb-16">
      <p class="text-orange-400 tracking-[0.2em] uppercase text-xs mb-3">Der Fotograf</p>
      <h1 class="text-4xl md:text-5xl font-thin">Über mich</h1>
      <div class="mt-4 w-16 h-px bg-orange-400"></div>
    </div>

    <!-- Content -->
    <div class="grid md:grid-cols-2 gap-16 items-start">

      <!-- Portrait placeholder -->
      <div class="relative">
        <div class="aspect-[3/4] bg-zinc-900 overflow-hidden">
          <img
            src="/images/me.jpeg"
            alt="Portrait Guido Walther"
            class="w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/50 to-transparent"></div>
        </div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 border border-orange-400/30"></div>
      </div>

      <!-- Text -->
      <div class="space-y-6">
        <div>
          <h2 class="text-2xl font-thin text-orange-400 mb-4">Guido Walther</h2>
          <p class="text-zinc-400 leading-relaxed font-light">
            Seit vielen Jahren fasziniert mich die Fotografie als Weg, besondere Momente
            festzuhalten und die Welt durch ein anderes Auge zu sehen. Was als Hobby begann,
            ist inzwischen ein fester Teil meines Lebens geworden.
          </p>
        </div>

        <p class="text-zinc-400 leading-relaxed font-light">
          Mein fotografisches Interesse liegt vor allem bei der Tierwelt – die Geduld,
          die nötig ist, um einen Wolf, eine Eule oder einen exotischen Vogel im richtigen
          Moment zu erwischen, macht jede gelungene Aufnahme zu einem kleinen Triumph.
        </p>

        <p class="text-zinc-400 leading-relaxed font-light">
          Daneben fotografiere ich gerne in der Natur, Landschaften und – wenn sich die
          Gelegenheit ergibt – auch spannende Sportveranstaltungen wie das Feuerwerk der
          Turnkunst.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 pt-6 border-t border-zinc-800">
          <div>
            <div class="text-3xl font-thin text-orange-400">6+</div>
            <div class="text-zinc-500 text-sm mt-1">Galerien</div>
          </div>
          <div>
            <div class="text-3xl font-thin text-orange-400">300+</div>
            <div class="text-zinc-500 text-sm mt-1">Fotos auf Flickr</div>
          </div>
          <div>
            <div class="text-3xl font-thin text-orange-400">2017</div>
            <div class="text-zinc-500 text-sm mt-1">Erste Galerie</div>
          </div>
        </div>

        <!-- Links -->
        <div class="pt-4 flex gap-4 flex-wrap">
          <a
            href="https://guidowalther.myportfolio.com"
            target="_blank"
            rel="noopener"
            class="px-6 py-2.5 rounded-full border border-zinc-700 text-sm tracking-wider uppercase hover:border-orange-400 hover:text-orange-400 transition-colors"
          >
            Adobe Portfolio
          </a>
          <a
            href="https://www.flickr.com/photos/macnebelherr"
            target="_blank"
            rel="noopener"
            class="px-6 py-2.5 rounded-full border border-zinc-700 text-sm tracking-wider uppercase hover:border-orange-400 hover:text-orange-400 transition-colors"
          >
            Flickr
          </a>
          <a
            href="/contact"
            class="px-6 py-2.5 rounded-full bg-orange-400 text-zinc-950 text-sm tracking-wider uppercase font-medium hover:bg-orange-300 transition-colors"
          >
            Kontakt
          </a>
        </div>
      </div>
    </div>

    <!-- Ausrüstung -->
    <div class="mt-20 pt-16 border-t border-zinc-800">
      <p class="text-orange-400 tracking-[0.2em] uppercase text-xs mb-2">Mein Equipment</p>
      <h2 class="text-2xl font-thin mb-10">Ausrüstung</h2>

      <div class="grid md:grid-cols-2 gap-6">

        <!-- Kamera 1 -->
        <div class="bg-zinc-900 p-6 rounded-lg border border-zinc-800">
          <div class="flex items-start gap-4">
            <div class="text-orange-400 mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-light text-lg">Sony A7 V</h3>
              <p class="text-orange-400 text-xs tracking-wider uppercase mt-0.5">Vollformat · 35mm</p>
              <p class="text-zinc-500 text-sm mt-2 leading-relaxed">
                Meine Hauptkamera für anspruchsvolle Aufnahmen – perfekt für Tierwelt, Natur und Landschaft mit herausragender Bildqualität bei wenig Licht.
              </p>
            </div>
          </div>
        </div>

        <!-- Kamera 2 -->
        <div class="bg-zinc-900 p-6 rounded-lg border border-zinc-800">
          <div class="flex items-start gap-4">
            <div class="text-orange-400 mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <h3 class="text-white font-light text-lg">Sony A6700</h3>
              <p class="text-orange-400 text-xs tracking-wider uppercase mt-0.5">APS-C · Crop-Faktor 1,5×</p>
              <p class="text-zinc-500 text-sm mt-2 leading-relaxed">
                Meine kompakte Zweitkamera – ideal für Sport und Tierfotografie, wo der APS-C-Crop-Faktor effektiv mehr Reichweite bringt.
              </p>
            </div>
          </div>
        </div>

        <!-- Objektive -->
        <div class="bg-zinc-900 p-6 rounded-lg border border-zinc-800 md:col-span-2">
          <div class="flex items-start gap-4">
            <div class="text-orange-400 mt-1">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                <circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.5"/>
                <line x1="12" y1="2" x2="12" y2="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="12" y1="20" x2="12" y2="22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="2" y1="12" x2="4" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                <line x1="20" y1="12" x2="22" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="flex-1">
              <h3 class="text-white font-light text-lg">Objektive</h3>
              <p class="text-orange-400 text-xs tracking-wider uppercase mt-0.5">Je nach Einsatz</p>
              <p class="text-zinc-500 text-sm mt-2 leading-relaxed">
                Ich wähle meine Objektive je nach Motiv und Situation – von Weitwinkel für Landschaften bis Tele für scheue Tiere und Sportaufnahmen aus der Distanz.
              </p>
            </div>
          </div>
        </div>

      </div>
    </div>

  </div>
</BaseLayout>
